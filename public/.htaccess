# ─── Compresión gzip ───────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/css
  AddOutputFilterByType DEFLATE application/javascript application/json
  AddOutputFilterByType DEFLATE image/svg+xml font/woff2 font/woff
</IfModule>

# ─── Cache de activos estáticos ────────────────────────────────────────────
<IfModule mod_expires.c>
  ExpiresActive On
  # Imágenes y fuentes — 1 año (no cambian, tienen hash en el nombre)
  ExpiresByType image/webp        "access plus 1 year"
  ExpiresByType image/jpeg        "access plus 1 year"
  ExpiresByType image/png         "access plus 1 year"
  ExpiresByType image/svg+xml     "access plus 1 year"
  ExpiresByType font/woff2        "access plus 1 year"
  ExpiresByType font/woff         "access plus 1 year"
  # JS y CSS — 1 año (Vite agrega hash al nombre en cada build)
  ExpiresByType text/css          "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  # HTML — corto (es el entry point del SPA, debe estar fresco)
  ExpiresByType text/html         "access plus 1 hour"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.(webp|jpg|jpeg|png|gif|ico|svg|woff2|woff)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "max-age=31536000, public, immutable"
  </FilesMatch>
  <FilesMatch "\.html$">
    Header set Cache-Control "max-age=3600, public"
  </FilesMatch>
</IfModule>

# ─── SPA routing — redirigir todo a index.html ─────────────────────────────
# Sin esto, URLs como /blog/burnout dan 404 al acceder directo
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  RewriteRule ^index\.html$ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . /index.html [L]
</IfModule>
